{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/parceiros",
      "destination": "https://app.inspirar.app/parceiros",
      "permanent": false
    },
    {
      "source": "/baixar",
      "destination": "https://app.inspirar.app/baixar",
      "permanent": false
    },
    {
      "source": "/app",
      "destination": "https://app.inspirar.app/baixar",
      "permanent": false
    }
  ]
}
